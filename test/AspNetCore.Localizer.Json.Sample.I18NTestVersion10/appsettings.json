{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JsonLocalizationOptions": {
    "ResourcesPath": "i18n",
    "AdditionalResourcesPaths": [ "common_i18n" ],
    "CacheDuration": "00:00:15",
    "DefaultCulture": "en-US",
    "DefaultUICulture": "en-US",
    "SupportedCultureInfos": [ "en-US", "fr-FR", "ar-AR" ],
    "FileEncodingName": "utf-8",
    "LocalizerDiagnosticMode": false,
    "MaxMissingTranslations": 1000,
    "MissingTranslationRetention": "00:01:00"
  }
}
